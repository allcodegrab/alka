{
  "name": "forge",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Forge — AI-native code editor with multi-agent engineering team",
  "license": "MIT",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "check": "turbo run lint typecheck format-check",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"packages/*/src/**/*.ts\"",
    "format-check": "prettier --check \"packages/*/src/**/*.ts\"",
    "clean": "turbo run clean"
  },
  "packageManager": "pnpm@10.20.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "eslint": "^10.4.0",
    "prettier": "^3.8.3",
    "turbo": "^2.9.14",
    "typescript": "5.8.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "3.2.1"
  }
}
