	"tokenColors": [
		{
			"scope": [
				"meta.embedded",
				"source.groovy.embedded",
				"string meta.image.inline.markdown",
				"variable.legacy.builtin.python"
			],
			"settings": {
				"foreground": "#E8EAED"
			}
		},
		{
			"scope": "emphasis",
			"settings": {
				"fontStyle": "italic"
			}
		},
		{
			"scope": "strong",
			"settings": {
				"fontStyle": "bold"
			}
		},
		{
			"scope": "comment",
			"settings": {
				"foreground": "#6B7280",
				"fontStyle": "italic"
			}
		},
		{
			"scope": [
				"keyword",
				"keyword.control",
				"storage",
				"storage.type",
				"storage.modifier"
			],
			"settings": {
				"foreground": "#E07B3B"
			}
		},
		{
			"scope": [
				"keyword.operator"
			],
			"settings": {
				"foreground": "#9CA3AF"
			}
		},
		{
			"scope": [
				"keyword.operator.new",
				"keyword.operator.expression",
				"keyword.operator.cast",
				"keyword.operator.sizeof",
				"keyword.operator.instanceof",
				"keyword.operator.logical.python",
				"keyword.operator.wordlike"
			],
			"settings": {
				"foreground": "#E07B3B"
			}
		},
		{
			"scope": [
				"string",
				"meta.embedded.assembly"
			],
			"settings": {
				"foreground": "#B8C238"
			}
		},
		{
			"scope": "string.regexp",
			"settings": {
				"foreground": "#D19A66"
			}
		},
		{
			"scope": [
				"constant.numeric",
				"variable.other.enummember",
				"keyword.operator.plus.exponent",
				"keyword.operator.minus.exponent"
			],
			"settings": {
				"foreground": "#4C8DFF"
			}
		},
		{
			"scope": "constant.language",
			"settings": {
				"foreground": "#4C8DFF"
			}
		},
		{
			"scope": "constant.regexp",
			"settings": {
				"foreground": "#D19A66"
			}
		},
		{
			"scope": [
				"entity.name.type",
				"entity.name.class",
				"support.type",
				"support.class"
			],
			"settings": {
				"foreground": "#A8D4FF"
			}
		},
		{
			"scope": [
				"entity.name.function",
				"support.function"
			],
			"settings": {
				"foreground": "#E8EAED"
			}
		},
		{
			"scope": "entity.name.tag",
			"settings": {
				"foreground": "#E07B3B"
			}
		},
		{
			"scope": "entity.other.attribute-name",
			"settings": {
				"foreground": "#A8D4FF"
			}
		},
		{
			"scope": [
				"variable",
				"variable.other",
				"variable.parameter"
			],
			"settings": {
				"foreground": "#E8EAED"
			}
		},
		{
			"scope": "variable.language",
			"settings": {
				"foreground": "#E07B3B"
			}
		},
		{
			"scope": [
				"support.type.vendored.property-name",
				"support.type.property-name",
				"source.css variable"
			],
			"settings": {
				"foreground": "#A8D4FF"
			}
		},
		{
			"scope": [
				"punctuation",
				"meta.brace"
			],
			"settings": {
				"foreground": "#6B7280"
			}
		},
		{
			"scope": [
				"punctuation.definition.template-expression.begin",
				"punctuation.definition.template-expression.end",
				"punctuation.section.embedded"
			],
			"settings": {
				"foreground": "#E07B3B"
			}
		},
		{
			"scope": "meta.template.expression",
			"settings": {
				"foreground": "#E8EAED"
			}
		},
		{
			"scope": "meta.objectliteral",
			"settings": {
				"foreground": "#E8EAED"
			}
		},
		{
			"scope": [
				"entity.name.tag.css",
				"entity.name.tag.less",
				"entity.other.attribute-name.class.css",
				"entity.other.attribute-name.id.css",
				"entity.other.attribute-name.pseudo-class.css",
				"entity.other.attribute-name.pseudo-element.css"
			],
			"settings": {
				"foreground": "#D19A66"
			}
		},
		{
			"scope": "invalid",
			"settings": {
				"foreground": "#E5484D"
			}
		},
		{
			"scope": "markup.heading",
			"settings": {
				"fontStyle": "bold",
				"foreground": "#E07B3B"
			}
		},
		{
			"scope": "markup.bold",
			"settings": {
				"fontStyle": "bold",
				"foreground": "#E07B3B"
			}
		},
		{
			"scope": "markup.italic",
			"settings": {
				"fontStyle": "italic",
				"foreground": "#C586C0"
			}
		},
		{
			"scope": "markup.underline",
			"settings": {
				"fontStyle": "underline"
			}
		},
		{
			"scope": "markup.strikethrough",
			"settings": {
				"fontStyle": "strikethrough"
			}
		},
		{
			"scope": "markup.inline.raw",
			"settings": {
				"foreground": "#B8C238"
			}
		},
		{
			"scope": "markup.inserted",
			"settings": {
				"foreground": "#2EBD6F"
			}
		},
		{
			"scope": "markup.deleted",
			"settings": {
				"foreground": "#E5484D"
			}
		},
		{
			"scope": "markup.changed",
			"settings": {
				"foreground": "#4C8DFF"
			}
		},
		{
			"scope": "punctuation.definition.quote.begin.markdown",
			"settings": {
				"foreground": "#6B7280"
			}
		},
		{
			"scope": "punctuation.definition.list.begin.markdown",
			"settings": {
				"foreground": "#FF5C1F"
			}
		},
		{
			"scope": "punctuation.definition.tag",
			"settings": {
				"foreground": "#6B7280"
			}
		},
		{
			"scope": "meta.diff.header",
			"settings": {
				"foreground": "#E07B3B"
			}
		},
		{
			"scope": [
				"meta.preprocessor",
				"entity.name.function.preprocessor"
			],
			"settings": {
				"foreground": "#E07B3B"
			}
		},
		{
			"scope": "meta.preprocessor.string",
			"settings": {
				"foreground": "#B8C238"
			}
		},
		{
			"scope": "meta.preprocessor.numeric",
			"settings": {
				"foreground": "#4C8DFF"
			}
		},
		{
			"scope": "meta.structure.dictionary.key.python",
			"settings": {
				"foreground": "#A8D4FF"
			}
		},
		{
			"scope": "keyword.other.unit",
			"settings": {
				"foreground": "#4C8DFF"
			}
		},
		{
			"scope": "support.function.git-rebase",
			"settings": {
				"foreground": "#A8D4FF"
			}
		},
		{
			"scope": "constant.sha.git-rebase",
			"settings": {
				"foreground": "#4C8DFF"
			}
		},
		{
			"scope": [
				"storage.modifier.import.java",
				"variable.language.wildcard.java",
				"storage.modifier.package.java"
			],
			"settings": {
				"foreground": "#E8EAED"
			}
		},
		{
			"scope": [
				"entity.other.attribute-name.class.css",
				"source.css entity.other.attribute-name.class"
			],
			"settings": {
				"foreground": "#D19A66"
			}
		},
		{
			"name": "Decorator / Annotation",
			"scope": [
				"meta.decorator",
				"meta.decorator entity.name.function",
				"storage.type.annotation"
			],
			"settings": {
				"foreground": "#FF5C1F"
			}
		}
	],
	"semanticHighlighting": true,
	"semanticTokenColors": {
		"newOperator": "#E07B3B",
		"stringLiteral": "#B8C238",
		"customLiteral": "#E8EAED",
		"numberLiteral": "#4C8DFF"
	}
}
