# =============================================================================
# .dockerignore — recommended for Dockerfile builds
# =============================================================================
# Without this file, the entire repo is sent to the Docker build daemon as
# context. That includes .git/, node_modules/, .claude/, secrets — all
# potentially baked into image layers if a COPY . is broad.
# =============================================================================

# -----------------------------------------------------------------------------
# VCS
# -----------------------------------------------------------------------------
.git/
.gitignore
.gitattributes
.gitmodules

# -----------------------------------------------------------------------------
# Claude artifacts (none of this should be in production images)
# -----------------------------------------------------------------------------
.claude/
.claudeignore
.claudeignore.cache

# -----------------------------------------------------------------------------
# Environment files (use --secret or build args, not COPY)
# -----------------------------------------------------------------------------
.env
.env.*
*.env

# -----------------------------------------------------------------------------
# Credentials
# -----------------------------------------------------------------------------
*.pem
*.key
*.p12
*.pfx
secrets.json
credentials.json
.aws/
.gcp/
.azure/

# -----------------------------------------------------------------------------
# Dependencies (let the Dockerfile install fresh)
# -----------------------------------------------------------------------------
node_modules/
.npm/
.yarn/
.pnpm-store/
__pycache__/
.venv/
venv/
target/
.gradle/

# -----------------------------------------------------------------------------
# Tests (production images shouldn't carry them)
# -----------------------------------------------------------------------------
tests/
__tests__/
*.test.js
*.test.ts
*.spec.js
*.spec.ts
coverage/
.nyc_output/
.pytest_cache/

# -----------------------------------------------------------------------------
# Build outputs (let Dockerfile build fresh)
# -----------------------------------------------------------------------------
dist/
build/
out/

# -----------------------------------------------------------------------------
# Source maps
# -----------------------------------------------------------------------------
*.map
*.js.map
*.css.map

# -----------------------------------------------------------------------------
# Editor / OS
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
*.bak
*.orig
*~

# -----------------------------------------------------------------------------
# CI / dev tooling
# -----------------------------------------------------------------------------
.github/
.gitlab-ci.yml
.circleci/
.travis.yml
.eslintrc*
.prettierrc*
.editorconfig
.babelrc*

# -----------------------------------------------------------------------------
# Documentation (keep README at runtime if needed, exclude rest)
# -----------------------------------------------------------------------------
docs/
*.md
!LICENSE.md
!README.md

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/
npm-debug.log*
yarn-debug.log*

# -----------------------------------------------------------------------------
# Caches
# -----------------------------------------------------------------------------
.cache/
.next/
.nuxt/
.turbo/
.parcel-cache/
.swc/
*.tsbuildinfo

# -----------------------------------------------------------------------------
# Local Docker artifacts
# -----------------------------------------------------------------------------
docker-compose.override.yml
.docker/
