# =============================================================================
# .gitignore — recommended defaults for Claude Code projects
# =============================================================================
# Generated by repo-safety-net skill.
# Pair with .npmignore (if publishing to npm) and .dockerignore (if building images).
# Each ecosystem has its OWN ignore file with its OWN rules.
#
# Documented incidents this protects against:
# - March 31, 2026: Anthropic Claude Code source leak via missing *.map in .npmignore
# - April 2026: .claude/ leaking API tokens in npm packages
# - Recurring: .env files leaking despite incomplete .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Claude Code — local/personal state (NEVER commit)
# -----------------------------------------------------------------------------
# Personal hooks, possibly API keys, local-only overrides
.claude/settings.local.json
.claude/.local/

# Claude Code's own session state and transcripts
.claude/sessions/
.claude/transcripts/

# Multi-agent missions (transient, per-task)
.claude/missions/

# Subagent persistent memory (under ~/.claude/agent-memory typically, but if any local)
.claude/agent-memory/

# Caches
.claude/.cache/
.claudeignore.cache

# -----------------------------------------------------------------------------
# Claude Code — what stays committed (DO NOT add these)
# -----------------------------------------------------------------------------
# .claude/skills/        ← team-shared skills, commit
# .claude/agents/        ← team-shared custom subagents, commit
# .claude/commands/      ← team-shared slash commands, commit
# .claude/settings.json  ← team-shared settings (no secrets), commit
# .claude/memory/        ← curated team knowledge (per project-memory skill), commit
# .claude/hooks/         ← project hook scripts (no secrets in them), commit

# -----------------------------------------------------------------------------
# Environment files — SECRETS LIVE HERE
# -----------------------------------------------------------------------------
.env
.env.*
*.env
# Allow templates/examples (these are safe to commit)
!.env.example
!.env.template
!.env.sample

# -----------------------------------------------------------------------------
# Credentials, keys, certificates
# -----------------------------------------------------------------------------
*.pem
*.key
*.p12
*.pfx
*.cer
*.crt
*.pkcs12
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*
id_ecdsa
id_ecdsa.*
*.kdbx
secrets.json
secrets.yaml
secrets.yml
credentials.json
credentials.yaml
credentials.yml

# Cloud provider local configs
.aws/credentials
.aws/config
.gcp/
.azure/
firebase-service-account*.json
firebase-debug.log
*-service-account.json

# -----------------------------------------------------------------------------
# Source maps — leaked Claude Code's entire source
# -----------------------------------------------------------------------------
*.map
*.js.map
*.css.map
*.sourcemap

# -----------------------------------------------------------------------------
# Editor and OS files
# -----------------------------------------------------------------------------
*.bak
*.orig
*.swp
*.swo
*.swn
*~
.#*
\#*\#
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# IDE local state
.vscode/
.idea/
*.iml
*.iws
.project
.classpath
.settings/
.metadata/

# -----------------------------------------------------------------------------
# Dependencies (language-agnostic)
# -----------------------------------------------------------------------------
node_modules/
.npm/
.yarn/
.pnpm-store/
__pycache__/
*.pyc
*.pyo
.venv/
venv/
env/
target/
.gradle/
.m2/
vendor/

# -----------------------------------------------------------------------------
# Build outputs
# -----------------------------------------------------------------------------
dist/
build/
out/
*.egg-info/
*.class
*.jar
*.war
*.ear

# -----------------------------------------------------------------------------
# Test and coverage
# -----------------------------------------------------------------------------
coverage/
.nyc_output/
.coverage
htmlcov/
.pytest_cache/
.tox/
.hypothesis/

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.next/
.nuxt/
.cache/
