{
  "name": "@forge/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "node --loader ts-node/esm src/server.ts",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "format-check": "prettier --check \"src/**/*.ts\"",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@forge/protocol": "workspace:*",
    "@forge/team-mode": "workspace:*",
    "@forge/knowledge": "workspace:*",
    "@forge/dashboard": "workspace:*",
    "fastify": "5.3.3",
    "@fastify/static": "8.1.0",
    "@fastify/cors": "11.0.1"
  }
}
