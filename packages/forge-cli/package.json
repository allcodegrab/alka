{
  "name": "@forge/cli",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "bin": {
    "forge": "dist/main.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "format-check": "prettier --check \"src/**/*.ts\"",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@forge/protocol": "workspace:*",
    "@forge/team-mode": "workspace:*",
    "@forge/agent-runtime": "workspace:*",
    "@forge/skill-loader": "workspace:*",
    "commander": "13.1.0",
    "pino": "9.6.0",
    "pino-pretty": "13.0.0"
  }
}
